# Copy to .env and adjust. Never commit real secrets.

# --- Database ---------------------------------------------------------------
# SQLAlchemy DSN using the psycopg (v3) driver.
DATABASE_URL=postgresql+psycopg://taskpool:taskpool@db:5432/taskpool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_PRE_PING=true
DB_POOL_TIMEOUT_SECONDS=30

# Used only by docker-compose to initialise the postgres container.
POSTGRES_USER=taskpool
POSTGRES_PASSWORD=taskpool
POSTGRES_DB=taskpool
# Host port mapped to Postgres (default 5433 avoids conflict with local Postgres on 5432)
POSTGRES_HOST_PORT=5433

# --- Consumer behaviour -----------------------------------------------------
# Comma-separated subset of topics this consumer handles. Empty = all topics.
TASKPOOL_TOPICS=
POLL_INTERVAL_SECONDS=1.0
POLL_JITTER_SECONDS=0.25
DB_RETRY_BACKOFF_SECONDS=2.0
DB_RETRY_MAX_BACKOFF_SECONDS=30.0

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Operational / hardening ------------------------------------------------
ABANDONED_THRESHOLD_SECONDS=900
MAX_PAYLOAD_BYTES=65536
MAX_ERROR_MESSAGE_CHARS=2000
MAX_ERROR_TYPE_CHARS=255
